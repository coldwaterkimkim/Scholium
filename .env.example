# Required
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL_PASS1=gpt-5.4
OPENAI_MODEL_SYNTHESIS=gpt-5.4
OPENAI_MODEL_PASS2=gpt-5.4
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2
SCHEMA_VERSION=0.1
PROMPT_VERSION_PASS1=pass1_v0_1
PROMPT_VERSION_SYNTHESIS=synthesis_v0_1
PROMPT_VERSION_PASS2=pass2_v0_1

# Local app settings
FRONTEND_PORT=3000
BACKEND_PORT=8000
DOCUMENT_DB_PATH=./data/scholium_dev.sqlite3

# Data directories
RAW_PDFS_DIR=./data/raw_pdfs
RENDERED_PAGES_DIR=./data/rendered_pages
ANALYSIS_DIR=./data/analysis
LOGS_DIR=./data/logs
