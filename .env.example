# Local analysis provider
SCHOLIUM_LLM_PROVIDER=codex_cli
CODEX_CLI_BIN=codex
CODEX_CLI_TIMEOUT_SECONDS=300
CODEX_CLI_MODEL=gpt-5.5
CODEX_CLI_REASONING=medium
PASS1_MAX_WORKERS=3
# parser_first is the current default. legacy_llm keeps the old page-by-page LLM Pass1 for debug/rollback.
PASS1_MODE=parser_first
PASS1_ROUTING_MODE=hybrid
DOCUMENT_PARSER_BACKEND=pymupdf4llm
PARSER_SCHEMA_VERSION=parser_v0_2

# Default MVP mode: preprocess context first, generate explanations only after user selection.
SCHOLIUM_PRECOMPUTE_ANCHORED_EXPLANATIONS=false

# Optional OpenAI API fallback
# Set SCHOLIUM_LLM_PROVIDER=openai_api before using these.
OPENAI_API_KEY=
OPENAI_MODEL_PASS1=gpt-5.4
OPENAI_MODEL_SYNTHESIS=gpt-5.4
OPENAI_MODEL_PASS2=gpt-5.4
OPENAI_MODEL_SELECTION=gpt-5.5
OPENAI_MODEL_SELECTION_FOLLOW_UP=gpt-5.5
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2

SCHEMA_VERSION=0.2
PROMPT_VERSION_PASS1=pass1_v0_1
PROMPT_VERSION_SEMANTIC_GUIDE=semantic_guide_v0_1
PROMPT_VERSION_SYNTHESIS=synthesis_v0_1
PROMPT_VERSION_PASS2=pass2_v0_2
PROMPT_VERSION_SELECTION=selection_explanation_v0_1
PROMPT_VERSION_SELECTION_FOLLOW_UP=selection_follow_up_v0_1

# Local app settings
FRONTEND_PORT=3000
BACKEND_PORT=8000
DOCUMENT_DB_PATH=./data/scholium_dev.sqlite3

# Data directories
RAW_PDFS_DIR=./data/raw_pdfs
RENDERED_PAGES_DIR=./data/rendered_pages
ANALYSIS_DIR=./data/analysis
LOGS_DIR=./data/logs
