        {
          "block_id": "p5_b7",
          "block_type": "paragraph",
          "text": "Jan. 24, 2024",
          "bbox": [
            0.705495,
            0.572411,
            0.089842,
            0.013096
          ],
          "reading_order": 7
        },
        {
          "block_id": "p5_b8",
          "block_type": "heading",
          "text": "Financial regulator aims to benchmark Japan's stock market",
          "bbox": [
            0.21387,
            0.593748,
            0.568471,
            0.01704
          ],
          "reading_order": 8
        },
        {
          "block_id": "p5_b9",
          "block_type": "figure",
          "text": "",
          "bbox": [
            0.202782,
            0.618871,
            0.609151,
            0.117588
          ],
          "reading_order": 9
        },
        {
          "block_id": "p5_b10",
          "block_type": "paragraph",
          "text": "PBR serves as a metric to evaluate a company's market price relative to its book\nvalue. A ratio below 1 indicates that the stock price of a firm is less than the\nvalue derived from selling all of its assets at book value. Consequently, a PBR\nbelow 1 suggests that the investment may not be lucrative as the stock is valued\nlower than the sum of its asset values on the books.",
          "bbox": [
            0.201973,
            0.748694,
            0.591267,
            0.070452
          ],
          "reading_order": 10
        },
        {
          "block_id": "p5_b11",
          "block_type": "paragraph",
          "text": "The PBR of companies listed on the KOSPI and smaller equity markets\ncombined is 0.89 on average.",
          "bbox": [
            0.201973,
            0.82709,
            0.527859,
            0.027688
          ],
          "reading_order": 11
        },
        {
          "block_id": "p5_b12",
          "block_type": "paragraph",
