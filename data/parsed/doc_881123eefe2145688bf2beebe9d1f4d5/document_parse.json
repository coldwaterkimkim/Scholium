        {
          "block_id": "p5_b0",
          "block_type": "heading",
          "text": "How to resolve multicollinearity problem",
          "bbox": [
            0.023438,
            0.040347,
            0.647276,
            0.053193
          ],
          "reading_order": 0
        },
        {
          "block_id": "p5_b1",
          "block_type": "paragraph",
          "text": "I Method I: Disregard the explanatory variable with a large VIF",
          "bbox": [
