      "blocks": [
        {
          "block_id": "p12_b0",
          "block_type": "heading",
          "text": "Computing VIF using your code",
          "bbox": [
            0.023438,
            0.040347,
            0.513167,
            0.053193
          ],
          "reading_order": 0
        },
        {
          "block_id": "p12_b1",
          "block_type": "paragraph",
          "text": "compute_vif=function(x_mat)\n{",
          "bbox": [
            0.121094,
            0.15405,
            0.389212,
            0.082338
          ],
          "reading_order": 1
        },
        {
          "block_id": "p12_b2",
          "block_type": "paragraph",
          "text": "size_x=dim(x_mat)\nvif=0*x_mat[1,];rownames(vif)=\"VIF\"\nfor (i in 1:size_x[2])\n{",
          "bbox": [
            0.149925,
            0.250704,
            0.504534,
            0.178988
          ],
          "reading_order": 2
        },
        {
          "block_id": "p12_b3",
          "block_type": "paragraph",
          "text": "y=as.matrix(x_mat[,i]);\nx=as.matrix(x_mat[,-i])\nresult=summary(lm(y~x))\nvif[1,i]=1/(1-result$r.squared)\n}\nreturn(vif)\n}",
          "bbox": [
            0.121094,
            0.444008,
            0.749593,
            0.275642
          ],
          "reading_order": 3
        },
        {
          "block_id": "p12_b4",
          "block_type": "paragraph",
          "text": "> compute_vif(edu[,-1])",
